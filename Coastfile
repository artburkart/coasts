[coast]
name = "coasts"

[coast.setup]
packages = ["nodejs", "npm", "curl", "bash", "ca-certificates", "wget"]

[services.vite]
install = "cd coast-guard && npm install"
command = "cd coast-guard && VITE_API_HOST=host.docker.internal npm run dev -- --host 0.0.0.0"
port = 5173
restart = "on-failure"

[ports]
vite = 5173

[egress]
coastd-api = 31415
coastd-api-dev = 31416
